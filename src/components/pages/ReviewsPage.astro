---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromUrl, localizedPath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const rp = i.reviewsPage;
const contactPath = localizedPath('/contact/', lang);
---

<BaseLayout title={i.meta.reviews.title} description={i.meta.reviews.description}>

  <!-- PAGE HERO -->
  <section class="pt-36 pb-16 bg-white text-center">
    <div class="max-w-3xl mx-auto px-5">
      <span class="section-label justify-center">{rp.hero.label}</span>
      <h1 class="section-title text-forest-dark">{rp.hero.title}</h1>
      <p class="section-subtitle mx-auto">
        {rp.hero.subtitle}
      </p>

      <!-- Overall rating -->
      <div class="mt-8 inline-flex items-center gap-3 bg-gold/8 border border-gold/20 rounded-full px-6 py-3">
        <div class="flex items-center gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-gold font-extrabold text-lg">{rp.hero.rating}</span>
        <span class="text-gray-400 text-sm">{rp.hero.ratingSource}</span>
      </div>
    </div>
  </section>

  <!-- TEXT REVIEWS -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{rp.textReviews.label}</span>
        <h2 class="section-title text-forest-dark">{rp.textReviews.title}</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {rp.reviews.map((review, idx) => {
          const displayStars = review.stars || 5;

          return (
            <div class:list={[
              'reveal group bg-white border border-gray-200 rounded-2xl p-7 hover:border-gold/40 hover:-translate-y-1.5 hover:shadow-[0_16px_40px_rgba(26,74,46,0.08)] transition-all duration-500 flex flex-col relative overflow-hidden',
              idx === 0 && 'md:col-span-2 lg:col-span-1',
            ]}>
              <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-gold to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

              <!-- Stars -->
              <div class="flex items-center gap-0.5 mb-4">
                {Array.from({ length: displayStars }).map(() => (
                  <svg class="w-[18px] h-[18px] text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>

              <!-- Quote -->
              <div class="text-gold/20 text-5xl font-heading leading-none mb-2">&ldquo;</div>
              <blockquote class="text-gray-600 text-sm leading-relaxed mb-6 flex-1 italic">
                {review.text}
              </blockquote>

              <!-- Author -->
              <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-forest/10 to-gold/15 flex items-center justify-center text-sm font-bold text-forest shrink-0 border border-gray-200">
                  {review.initials}
                </div>
                <div class="min-w-0">
                  <div class="text-forest-dark text-sm font-semibold">{review.name}</div>
                  <div class="text-gray-400 text-xs">{review.role}</div>
                  {review.since && (
                    <div class="text-gold/70 text-[10px] font-semibold uppercase tracking-wider mt-0.5">{review.since}</div>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- VIDEO REVIEWS -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{rp.videoReviews.label}</span>
        <h2 class="section-title text-forest-dark">{rp.videoReviews.title}</h2>
        <p class="section-subtitle mx-auto">{rp.videoReviews.subtitle}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-8">
        {rp.videos.map((video, idx) => (
          <div class="reveal stagger" style={`--stagger: ${idx}`}>
            {video.youtubeId ? (
              <div class="group relative max-w-[320px] mx-auto">
                {/* Glow effect */}
                <div class="absolute -inset-3 bg-gradient-to-br from-gold/15 via-forest/10 to-gold/15 rounded-[2.5rem] opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-xl" />

                <div class="relative rounded-3xl overflow-hidden border border-gray-200 group-hover:border-gold/40 shadow-[0_8px_30px_rgba(0,0,0,0.06)] group-hover:shadow-[0_20px_60px_rgba(212,160,23,0.15)] transition-all duration-700 group-hover:-translate-y-2">
                  {/* Video */}
                  <div class="aspect-[9/16] w-[320px] bg-black">
                    <iframe
                      src={`https://www.youtube.com/embed/${video.youtubeId}`}
                      title={video.name}
                      class="w-full h-full"
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  </div>

                  {/* Info card */}
                  <div class="bg-gradient-to-br from-white to-gray-50 p-5">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-gold/20 to-forest/10 border border-gold/30 flex items-center justify-center shrink-0">
                        <span class="text-gold font-bold text-xs">{video.name.charAt(0)}</span>
                      </div>
                      <div>
                        <p class="text-forest-dark font-heading font-bold text-base">{video.name}</p>
                        <div class="flex items-center gap-2 mt-0.5">
                          <span class="text-gold/80 text-xs font-semibold">{video.age}</span>
                          <span class="w-1 h-1 rounded-full bg-gold/40" />
                          <span class="text-gray-400 text-xs flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                            </svg>
                            {video.location}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ) : (
              <div class="group max-w-[320px] mx-auto aspect-[9/16] rounded-3xl bg-gradient-to-br from-gray-50 via-white to-gray-100 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center gap-4 cursor-pointer hover:border-gold/30 hover:shadow-md transition-all duration-500 relative overflow-hidden">
                <div class="absolute top-8 right-8 w-16 h-16 bg-gold/5 rounded-full" />
                <div class="absolute bottom-12 left-8 w-12 h-12 bg-forest/5 rounded-full" />

                <div class="w-14 h-14 rounded-full bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 group-hover:scale-110 transition-all duration-300">
                  <svg class="w-7 h-7 text-gold ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
                <div class="text-center px-6">
                  <p class="text-gray-400 text-sm font-medium">{video.title || video.name}</p>
                  <p class="text-gray-300 text-[11px] mt-1.5 uppercase tracking-wider">{lang === 'uk' ? 'Скоро' : 'Coming soon'}</p>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-gradient-to-b from-forest-dark via-forest to-forest-dark py-20 overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold/5 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-gold/3 rounded-full blur-3xl pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-5 text-center">
      <div class="flex items-center justify-center gap-1 mb-6">
        {[1,2,3,4,5].map(() => (
          <svg class="w-6 h-6 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>

      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        {rp.cta.title}
      </h2>
      <p class="text-white/50 text-base md:text-lg mb-8 max-w-lg mx-auto">
        {rp.cta.subtitle}
      </p>
      <a href={contactPath} class="btn-gold !px-10 !py-4 !text-base group">
        {rp.cta.button}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
