---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromUrl, localizedPath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const pp = i.pricingPage;
const contactPath = localizedPath('/contact/', lang);

// Price data stays the same regardless of language — only labels change
const adultOnlineUa = [
  { name: pp.rows.trial, duration: pp.duration30, price: '300', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration45, price: '550', per: '550', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration45, price: '2 000', per: '500', saving: `${pp.savingLabel} 200 ${pp.currency.uah}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration45, price: '3 800', per: '475', saving: `${pp.savingLabel} 600 ${pp.currency.uah}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration45, price: '5 400', per: '450', saving: `${pp.savingLabel} 1 200 ${pp.currency.uah}`, popular: false },
];

const adultOfflineDnipro = [
  { name: pp.rows.trial, duration: pp.duration30, price: '350', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration45, price: '600', per: '600', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration45, price: '2 300', per: '575', saving: `${pp.savingLabel} 100 ${pp.currency.uah}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration45, price: '4 300', per: '537', saving: `${pp.savingLabel} 500 ${pp.currency.uah}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration45, price: '6 100', per: '508', saving: `${pp.savingLabel} 1 100 ${pp.currency.uah}`, popular: false },
];

const adultOnlineEu = [
  { name: pp.rows.trial, duration: pp.duration30, price: '12', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration45, price: '22', per: '22', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration45, price: '80', per: '20', saving: `${pp.savingLabel} 8 ${pp.currency.eur}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration45, price: '150', per: '18.75', saving: `${pp.savingLabel} 26 ${pp.currency.eur}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration45, price: '210', per: '17.50', saving: `${pp.savingLabel} 54 ${pp.currency.eur}`, popular: false },
];

const kidsOnlineUa = [
  { name: pp.rows.trial, duration: pp.duration2030, price: '250', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration30, price: '490', per: '490', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration30, price: '1 700', per: '425', saving: `${pp.savingLabel} 260 ${pp.currency.uah}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration30, price: '3 100', per: '387', saving: `${pp.savingLabel} 820 ${pp.currency.uah}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration30, price: '4 400', per: '366', saving: `${pp.savingLabel} 1 480 ${pp.currency.uah}`, popular: false },
];

const kidsOfflineDnipro = [
  { name: pp.rows.trial, duration: pp.duration2030, price: '300', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration30, price: '540', per: '540', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration30, price: '1 900', per: '475', saving: `${pp.savingLabel} 260 ${pp.currency.uah}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration30, price: '3 500', per: '437', saving: `${pp.savingLabel} 820 ${pp.currency.uah}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration30, price: '5 000', per: '416', saving: `${pp.savingLabel} 1 480 ${pp.currency.uah}`, popular: false },
];

const kidsOnlineEu = [
  { name: pp.rows.trial, duration: pp.duration2030, price: '8', per: '', saving: '', popular: false },
  { name: pp.rows.single, duration: pp.duration30, price: '15', per: '15', saving: '', popular: false },
  { name: pp.rows.package4, duration: pp.duration30, price: '55', per: '13.75', saving: `${pp.savingLabel} 5 ${pp.currency.eur}`, popular: false },
  { name: pp.rows.package8, duration: pp.duration30, price: '100', per: '12.50', saving: `${pp.savingLabel} 20 ${pp.currency.eur}`, popular: true },
  { name: pp.rows.package12, duration: pp.duration30, price: '140', per: '11.67', saving: `${pp.savingLabel} 40 ${pp.currency.eur}`, popular: false },
];
---

<BaseLayout title={i.meta.pricing.title} description={i.meta.pricing.description}>

  <!-- PAGE HERO -->
  <section class="pt-36 pb-10 bg-white text-center">
    <div class="max-w-3xl mx-auto px-5">
      <span class="section-label justify-center">{pp.hero.label}</span>
      <h1 class="section-title text-forest-dark">{pp.hero.title}</h1>
      <p class="section-subtitle mx-auto">{pp.hero.subtitle}</p>
    </div>
  </section>

  <!-- ADULT PRICING -->
  <section class="py-10 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5">

      <div class="text-center mb-10 reveal">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-gold/8 border border-gold/15 rounded-full mb-4">
          <span class="text-xl">{pp.adultBadgeIcon}</span>
          <span class="text-gold text-sm font-semibold">{pp.adultBadge}</span>
        </div>
      </div>

      <!-- Three columns -->
      <div class="grid md:grid-cols-3 gap-6">

        <!-- COLUMN 1: Online UA -->
        <div class="reveal bg-white border border-gray-200 rounded-2xl overflow-hidden">
          <div class="bg-gradient-to-r from-gray-50 to-white px-7 py-5 border-b border-gray-200">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a9 9 0 11-18 0V5.25"/>
              </svg>
              <h2 class="font-heading text-lg font-bold text-forest-dark">{pp.columns.onlineUa.title}</h2>
            </div>
            <p class="text-gray-500 text-xs">{pp.columns.onlineUa.sub}</p>
          </div>

          <div class="divide-y divide-gray-100">
            {adultOnlineUa.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-gray-50 transition-colors relative', row.popular && 'bg-gold/[0.04] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-forest font-semibold text-sm">{row.name}</h4>
                    <span class="text-gray-400 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-extrabold text-gold">{row.price}</span>
                      <span class="text-gray-500 text-xs">{pp.currency.uah}</span>
                    </div>
                  </div>
                </div>
                {(row.per || row.saving) && (
                  <div class="flex items-center justify-between gap-4">
                    {row.per && <span class="text-gray-400 text-xs">{row.per} {pp.currency.uah}/{pp.perLesson}</span>}
                    {row.saving && (
                      <span class="text-forest-dark text-xs font-semibold bg-gold/15 px-2.5 py-0.5 rounded-full">
                        {row.saving}
                      </span>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="px-7 py-5">
            <a href={contactPath} class="btn-gold w-full !py-3.5 text-center !text-sm">{pp.signUp}</a>
          </div>
        </div>

        <!-- COLUMN 2: Offline Dnipro -->
        <div class="reveal bg-white border border-gray-200 rounded-2xl overflow-hidden">
          <div class="bg-gradient-to-r from-gold/8 to-white px-7 py-5 border-b border-gray-200">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              <h2 class="font-heading text-lg font-bold text-forest-dark">{pp.columns.offlineDnipro.title}</h2>
            </div>
            <p class="text-gray-500 text-xs">{pp.columns.offlineDnipro.sub}</p>
          </div>

          <div class="divide-y divide-gray-100">
            {adultOfflineDnipro.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-gray-50 transition-colors relative', row.popular && 'bg-gold/[0.04] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-forest font-semibold text-sm">{row.name}</h4>
                    <span class="text-gray-400 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-extrabold text-gold">{row.price}</span>
                      <span class="text-gray-500 text-xs">{pp.currency.uah}</span>
                    </div>
                  </div>
                </div>
                {(row.per || row.saving) && (
                  <div class="flex items-center justify-between gap-4">
                    {row.per && <span class="text-gray-400 text-xs">{row.per} {pp.currency.uah}/{pp.perLesson}</span>}
                    {row.saving && (
                      <span class="text-forest-dark text-xs font-semibold bg-gold/15 px-2.5 py-0.5 rounded-full">
                        {row.saving}
                      </span>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="px-7 py-5">
            <a href={contactPath} class="btn-outline w-full !py-3.5 text-center !text-sm">{pp.signUp}</a>
          </div>
        </div>

        <!-- COLUMN 3: Online Europe EUR -->
        <div class="reveal bg-white border border-gold/30 rounded-2xl overflow-hidden ring-1 ring-gold/15">
          <div class="bg-gradient-to-r from-gray-50 to-white px-7 py-5 border-b border-gray-200">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
              </svg>
              <h2 class="font-heading text-lg font-bold text-forest-dark">{pp.columns.onlineEu.title}</h2>
            </div>
            <p class="text-gray-500 text-xs">{pp.columns.onlineEu.sub}</p>
          </div>

          <div class="divide-y divide-gray-100">
            {adultOnlineEu.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-gray-50 transition-colors relative', row.popular && 'bg-gold/[0.04] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-forest font-semibold text-sm">{row.name}</h4>
                    <span class="text-gray-400 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-extrabold text-gold">{row.price}</span>
                      <span class="text-gray-500 text-xs">{pp.currency.eur}</span>
                    </div>
                  </div>
                </div>
                {(row.per || row.saving) && (
                  <div class="flex items-center justify-between gap-4">
                    {row.per && <span class="text-gray-400 text-xs">{row.per} {pp.currency.eur}/{pp.perLesson}</span>}
                    {row.saving && (
                      <span class="text-forest-dark text-xs font-semibold bg-gold/15 px-2.5 py-0.5 rounded-full">
                        {row.saving}
                      </span>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="px-7 py-5">
            <a href={contactPath} class="btn-gold w-full !py-3.5 text-center !text-sm">{pp.signUp}</a>
          </div>
        </div>
      </div>

      <p class="text-gray-300 text-xs text-center mt-8 max-w-lg mx-auto leading-relaxed">
        {pp.note}
      </p>
    </div>
  </section>

  <!-- KIDS PRICING -->
  <section class="py-20 md:py-28 bg-forest-dark relative overflow-hidden" id="kidsSection">
    <div class="absolute -top-32 -right-32 w-[400px] h-[400px] bg-gold/5 rounded-full blur-[100px] pointer-events-none" />
    <div class="absolute -bottom-24 -left-24 w-[300px] h-[300px] bg-gold/3 rounded-full blur-[80px] pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="inline-flex items-center gap-3 text-xs font-bold tracking-[0.2em] uppercase text-gold mb-4">
          <span class="block w-5 h-0.5 bg-gold rounded-full" />
          {pp.kids.label}
        </span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4 text-cream">
          {pp.kids.title}
        </h2>
        <p class="text-cream/40 text-base md:text-lg max-w-xl mx-auto">
          {pp.kids.subtitle}
        </p>
        <div class="inline-flex items-center gap-2 mt-5 px-4 py-2 bg-gold/10 border border-gold/20 rounded-full">
          <span class="text-2xl">{pp.kids.badgeIcon}</span>
          <span class="text-gold text-sm font-semibold">{pp.kids.badge}</span>
        </div>
      </div>

      <!-- Three columns -->
      <div class="grid md:grid-cols-3 gap-6">

        <!-- COLUMN 1: Online UA -->
        <div class="reveal bg-forest/60 backdrop-blur-sm border border-cream/10 rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-cream/10 bg-cream/[0.03]">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a9 9 0 11-18 0V5.25"/>
              </svg>
              <h3 class="font-heading text-lg font-bold text-cream">{pp.kids.columns.onlineUa.title}</h3>
            </div>
            <p class="text-cream/30 text-xs">{pp.kids.columns.onlineUa.sub}</p>
          </div>

          <div class="divide-y divide-cream/5">
            {kidsOnlineUa.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-cream/[0.03] transition-colors relative', row.popular && 'bg-gold/[0.06] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-cream/90 font-semibold text-sm">{row.name}</h4>
                    <span class="text-cream/30 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-extrabold text-gold">{row.price}</span>
                      <span class="text-cream/40 text-xs">{pp.currency.uah}</span>
                    </div>
                  </div>
                </div>
                {(row.per || row.saving) && (
                  <div class="flex items-center justify-between gap-4">
                    {row.per && <span class="text-cream/30 text-xs">{row.per} {pp.currency.uah}/{pp.perLesson}</span>}
                    {row.saving && (
                      <span class="text-forest-dark text-xs font-semibold bg-gold/20 text-gold px-2.5 py-0.5 rounded-full">
                        {row.saving}
                      </span>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="px-7 py-5">
            <a href={contactPath} class="btn-gold w-full !py-3.5 text-center !text-sm">{pp.signUp}</a>
          </div>
        </div>

        <!-- COLUMN 2: Offline Dnipro -->
        <div class="reveal bg-forest/60 backdrop-blur-sm border border-cream/10 rounded-2xl overflow-hidden">
          <div class="px-7 py-5 border-b border-cream/10 bg-gold/[0.06]">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
              <h3 class="font-heading text-lg font-bold text-cream">{pp.kids.columns.offlineDnipro.title}</h3>
            </div>
            <p class="text-cream/30 text-xs">{pp.kids.columns.offlineDnipro.sub}</p>
          </div>

          <div class="divide-y divide-cream/5">
            {kidsOfflineDnipro.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-cream/[0.03] transition-colors relative', row.popular && 'bg-gold/[0.06] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-cream/90 font-semibold text-sm">{row.name}</h4>
                    <span class="text-cream/30 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
                    <div class="flex items-baseline gap-1">
                      <span class="text-xl font-extrabold text-gold">{row.price}</span>
                      <span class="text-cream/40 text-xs">{pp.currency.uah}</span>
                    </div>
                  </div>
                </div>
                {(row.per || row.saving) && (
                  <div class="flex items-center justify-between gap-4">
                    {row.per && <span class="text-cream/30 text-xs">{row.per} {pp.currency.uah}/{pp.perLesson}</span>}
                    {row.saving && (
                      <span class="text-forest-dark text-xs font-semibold bg-gold/20 text-gold px-2.5 py-0.5 rounded-full">
                        {row.saving}
                      </span>
                    )}
                  </div>
                )}
              </div>
            ))}
          </div>

          <div class="px-7 py-5">
            <a href={contactPath} class="btn-outline w-full !py-3.5 text-center !text-sm !border-cream/20 !text-cream hover:!border-gold hover:!bg-gold hover:!text-white">{pp.signUp}</a>
          </div>
        </div>

        <!-- COLUMN 3: Online Europe EUR -->
        <div class="reveal bg-forest/60 backdrop-blur-sm border border-gold/30 rounded-2xl overflow-hidden ring-1 ring-gold/20">
          <div class="px-7 py-5 border-b border-cream/10 bg-cream/[0.03]">
            <div class="flex items-center gap-3 mb-1">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
              </svg>
              <h3 class="font-heading text-lg font-bold text-cream">{pp.kids.columns.onlineEu.title}</h3>
            </div>
            <p class="text-cream/30 text-xs">{pp.kids.columns.onlineEu.sub}</p>
          </div>

          <div class="divide-y divide-cream/5">
            {kidsOnlineEu.map((row) => (
              <div class:list={['px-7 py-5 hover:bg-cream/[0.03] transition-colors relative', row.popular && 'bg-gold/[0.06] border-l-2 border-l-gold']}>
                {row.popular && (
                  <span class="absolute top-3 right-4 px-2.5 py-0.5 bg-gold text-forest-dark text-[9px] font-bold rounded-full uppercase tracking-wider">{pp.popular}</span>
                )}
                <div class="flex items-center justify-between gap-4 mb-2">
                  <div>
                    <h4 class="text-cream/90 font-semibold text-sm">{row.name}</h4>
                    <span class="text-cream/30 text-xs">{row.duration}</span>
                  </div>
                  <div class="text-right">
