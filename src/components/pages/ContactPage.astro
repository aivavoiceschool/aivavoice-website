---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromUrl } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const c = i.contact;
const f = c.form;
---

<BaseLayout title={i.meta.contact.title} description={i.meta.contact.description}>

  <!-- Page Hero -->
  <section class="pt-36 pb-16 bg-white text-center">
    <div class="max-w-3xl mx-auto px-5">
      <span class="section-label justify-center">{c.label}</span>
      <h1 class="section-title text-forest">{c.title}</h1>
      <p class="section-subtitle mx-auto">{c.subtitle}</p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid lg:grid-cols-2 gap-12">

        <!-- LEFT: Info -->
        <div class="space-y-6 reveal">
          <div class="mb-4">
            <h2 class="font-heading text-2xl font-bold text-forest mb-2">{c.inTouch}</h2>
            <p class="text-gray-500 text-sm leading-relaxed">{c.inTouchSub}</p>
          </div>

          <!-- Phone -->
          <div class="flex items-center gap-4 p-5 bg-white border border-gray-200 rounded-2xl hover:border-gold/15 transition-colors duration-300">
            <div class="w-12 h-12 rounded-xl bg-gold/8 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
            </div>
            <div>
              <div class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-0.5">{c.phone.label}</div>
              <a href="tel:+380685490047" class="text-gold font-semibold text-sm hover:text-gold-hover transition-colors">{c.phone.value}</a>
              <div class="text-gray-400 text-xs mt-0.5">{c.phone.sub}</div>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center gap-4 p-5 bg-white border border-gray-200 rounded-2xl hover:border-gold/15 transition-colors duration-300">
            <div class="w-12 h-12 rounded-xl bg-gold/8 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </div>
            <div>
              <div class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-0.5">{c.email.label}</div>
              <a href="mailto:aivavoiceschool@gmail.com" class="text-gold font-semibold text-sm hover:text-gold-hover transition-colors break-all">{c.email.value}</a>
              <div class="text-gray-400 text-xs mt-0.5">{c.email.sub}</div>
            </div>
          </div>

          <!-- Address -->
          <a href="https://www.google.com/maps/search/?api=1&query=Дмитра+Яворницького+49+Дніпро" target="_blank" rel="noopener" class="flex items-center gap-4 p-5 bg-white border border-gray-200 rounded-2xl hover:border-gold/15 transition-colors duration-300 group cursor-pointer no-underline">
            <div class="w-12 h-12 rounded-xl bg-gold/8 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-gray-400 text-xs font-semibold uppercase tracking-wider mb-0.5">{c.address.label}</div>
              <div class="text-forest-dark font-semibold text-sm group-hover:text-gold transition-colors">{c.address.value}</div>
              <div class="text-gray-400 text-xs mt-0.5">{c.address.sub}</div>
            </div>
          </a>

          <!-- Schedule -->
          <div class="p-5 bg-white border border-gray-200 rounded-2xl hover:border-gold/15 transition-colors duration-300">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-gold/8 flex items-center justify-center shrink-0">
                <svg class="w-[18px] h-[18px] text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="text-gray-400 text-xs font-semibold uppercase tracking-wider">{c.schedule.label}</div>
            </div>
            <div class="grid grid-cols-3 gap-2">
              {c.schedule.lines.map((line, idx) => {
                const parts = line.split(': ');
                const isOff = idx === c.schedule.lines.length - 1 && (parts[1] === 'вихідний' || parts[1] === 'Day off');
                return (
                  <div class:list={[
                    'rounded-xl p-3 text-center border transition-colors duration-300',
                    isOff
                      ? 'bg-forest-dark/5 border-forest-dark/10'
                      : 'bg-gold/5 border-gold/10 hover:border-gold/25',
                  ]}>
                    <div class:list={[
                      'text-[11px] font-bold uppercase tracking-wider mb-1',
                      isOff ? 'text-forest-dark/50' : 'text-gold',
                    ]}>{parts[0]}</div>
                    <div class:list={[
                      'text-sm font-semibold',
                      isOff ? 'text-forest-dark/50' : 'text-forest-dark',
                    ]}>{parts[1] || parts[0]}</div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Social links -->
          <div class="pt-2">
            <h4 class="text-forest-dark text-sm font-semibold mb-3">{c.socialTitle}</h4>
            <div class="flex flex-col gap-3">
              <!-- Telegram -->
              <a href={c.social.telegram.url} target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-5 py-3 bg-white border border-gray-200 rounded-xl hover:border-gold/30 hover:-translate-y-0.5 transition-all duration-300 group">
                <div class="w-9 h-9 rounded-lg bg-[#229ED9]/10 flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-[#229ED9]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
                </div>
                <div>
                  <span class="text-forest-dark text-sm font-semibold group-hover:text-gold transition-colors">{c.social.telegram.label}</span>
                  <span class="text-gray-400 text-xs ml-2">{c.social.telegram.handle}</span>
                </div>
              </a>
              <!-- Viber -->
              <a href={c.social.viber.url} class="inline-flex items-center gap-3 px-5 py-3 bg-white border border-gray-200 rounded-xl hover:border-gold/30 hover:-translate-y-0.5 transition-all duration-300 group">
                <div class="w-9 h-9 rounded-lg bg-[#7360F2]/10 flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-[#7360F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91-.01-2.65-1.04-5.13-2.9-6.99A9.816 9.816 0 0012.04 2zm5.63 13.59c-.23.65-1.36 1.22-1.89 1.3-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.65-.6-2.9-1.24-4.79-4.15-4.93-4.34-.15-.19-1.17-1.56-1.17-2.97 0-1.42.74-2.12 1-2.41.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.58.82 2 .89 2.15.07.14.12.31.02.5-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.78 1.28 1.67 2.07 1.14 1.02 2.11 1.33 2.41 1.48.29.15.46.13.64-.08.17-.21.75-.87.95-1.17.19-.29.39-.24.66-.15.27.1 1.71.81 2 .95.29.15.48.22.56.34.07.12.07.68-.16 1.33z"/></svg>
                </div>
                <div>
                  <span class="text-forest-dark text-sm font-semibold group-hover:text-gold transition-colors">{c.social.viber.label}</span>
                  <span class="text-gray-400 text-xs ml-2">{c.social.viber.handle}</span>
                </div>
              </a>
              <!-- Instagram -->
              <a href={c.social.instagram.url} target="_blank" rel="noopener" class="inline-flex items-center gap-3 px-5 py-3 bg-white border border-gray-200 rounded-xl hover:border-gold/30 hover:-translate-y-0.5 transition-all duration-300 group">
                <div class="w-9 h-9 rounded-lg bg-[#E1306C]/10 flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-[#E1306C]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </div>
                <div>
                  <span class="text-forest-dark text-sm font-semibold group-hover:text-gold transition-colors">{c.social.instagram.label}</span>
                  <span class="text-gray-400 text-xs ml-2">{c.social.instagram.handle}</span>
                </div>
              </a>
            </div>
          </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="reveal bg-white border border-gray-200 rounded-2xl p-8" id="contactFormWrapper">
          <h3 class="font-heading text-xl font-bold text-forest mb-6">{f.title}</h3>

          <form id="contactForm" class="space-y-5">
            <!-- Hidden lang field -->
            <input type="hidden" name="lang" value={lang} />

            <!-- Name -->
            <div>
              <label for="name" class="block text-xs font-semibold text-gray-600 mb-2">{f.name} *</label>
              <input
                type="text" id="name" name="name" required
                placeholder={f.namePlaceholder}
                class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-forest-dark text-sm placeholder:text-gray-300 outline-none focus:border-gold focus:ring-2 focus:ring-gold/10 transition-all"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-xs font-semibold text-gray-600 mb-2">{f.phone} *</label>
              <input
                type="tel" id="phone" name="phone" required
                placeholder={f.phonePlaceholder}
                class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-forest-dark text-sm placeholder:text-gray-300 outline-none focus:border-gold focus:ring-2 focus:ring-gold/10 transition-all"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-xs font-semibold text-gray-600 mb-2">{f.message}</label>
              <textarea
                id="message" name="message" rows="4"
                placeholder={f.messagePlaceholder}
                class="w-full px-4 py-3.5 bg-gray-50 border border-gray-200 rounded-xl text-forest-dark text-sm placeholder:text-gray-300 outline-none focus:border-gold focus:ring-2 focus:ring-gold/10 transition-all resize-y min-h-[120px]"
              />
            </div>

            <!-- Cloudflare Turnstile (uncomment when sitekey is configured) -->
            <!-- <div class="cf-turnstile" data-sitekey="YOUR_SITEKEY" data-theme="light"></div> -->

            <!-- Error message -->
            <div id="formError" class="hidden text-red-500 text-sm font-medium bg-red-50 border border-red-200 rounded-xl px-4 py-3">
              {f.error}
            </div>

            <button type="submit" id="submitBtn" class="btn-gold w-full !py-4 cursor-pointer">
              {f.submit}
            </button>
          </form>

          <!-- Success -->
          <div id="formSuccess" class="hidden text-center py-10">
            <div class="w-16 h-16 rounded-full bg-gold/15 text-gold text-3xl flex items-center justify-center mx-auto mb-5">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-forest mb-2">{f.success.title}</h3>
            <p class="text-gray-500 text-sm">{f.success.text}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="pb-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="reveal rounded-2xl overflow-hidden border border-gray-200 shadow-[0_8px_30px_rgba(0,0,0,0.06)]">
        <div class="relative">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2645.8!2d35.0462!3d48.4647!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40dbe2de1c4b0a3f%3A0x8e7e1e0a1c3b0a0a!2z0L_RgC4g0JTQvNC40YLRgNCwINCv0LLQvtGA0L3QuNGG0YzQutC-0LPQviA0OSwg0JTQvdGW0L_RgNC-!5e0!3m2!1suk!2sua!4v1700000000000!5m2!1suk!2sua"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={lang === 'uk' ? 'Карта — пр. Дмитра Яворницького 49, Дніпро' : 'Map — Dmytra Yavornytskoho Ave 49, Dnipro'}
          />
        </div>
        <div class="bg-white px-6 py-4 flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-forest-dark font-semibold text-sm">{lang === 'uk' ? 'пр. Дмитра Яворницького 49' : 'Dmytra Yavornytskoho Ave 49'}</p>
              <p class="text-gray-400 text-xs">{lang === 'uk' ? 'Дніпро, Україна' : 'Dnipro, Ukraine'}</p>
            </div>
          </div>
          <a
            href="https://www.google.com/maps/search/?api=1&query=Дмитра+Яворницького+49+Дніпро"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-forest text-white text-sm font-semibold rounded-xl hover:bg-forest-dark transition-colors duration-300"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
            {lang === 'uk' ? 'Відкрити в Google Maps' : 'Open in Google Maps'}
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Cloudflare Turnstile script -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  // Phone mask
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  if (phoneInput) {
    phoneInput.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      let val = target.value.replace(/\D/g, '');
      if (val.startsWith('380')) { /* keep */ }
      else if (val.startsWith('80')) val = '3' + val;
      else if (val.startsWith('0')) val = '38' + val;
      else if (!val.startsWith('3')) val = '380' + val;

      let formatted = '+';
      if (val.length > 0) formatted += val.substring(0, 3);
      if (val.length > 3) formatted += ' ' + val.substring(3, 5);
      if (val.length > 5) formatted += ' ' + val.substring(5, 8);
      if (val.length > 8) formatted += ' ' + val.substring(8, 10);
      if (val.length > 10) formatted += ' ' + val.substring(10, 12);
      target.value = formatted;
    });
  }

  // Form submit -> /api/contact
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const formError = document.getElementById('formError') as HTMLDivElement;
  const formSuccess = document.getElementById('formSuccess') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      formError.classList.add('hidden');

      // Validate phone
      if (phoneInput) {
        const digits = phoneInput.value.replace(/\D/g, '');
        if (digits.length < 12) {
          phoneInput.setCustomValidity(phoneInput.dataset.validationMsg || 'Please enter a complete phone number');
          phoneInput.reportValidity();
          phoneInput.addEventListener('input', () => phoneInput.setCustomValidity(''), { once: true });
          return;
        }
      }

      // Get Turnstile token
      const turnstileInput = form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement;
      const turnstileToken = turnstileInput?.value || '';

      // Get lang
      const langInput = form.querySelector('[name="lang"]') as HTMLInputElement;
      const formLang = langInput?.value || 'uk';

      // Disable button
      const originalText = submitBtn.textContent;
      submitBtn.textContent = submitBtn.dataset.sendingText || 'Sending...';
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-60', 'cursor-not-allowed');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: (document.getElementById('name') as HTMLInputElement).value.trim(),
            phone: phoneInput.value.trim(),
            message: (document.getElementById('message') as HTMLTextAreaElement).value.trim(),
            turnstileToken,
            lang: formLang,
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || 'Server error');
        }

        // Success
        form.style.display = 'none';
        formSuccess.classList.remove('hidden');

        // GA4 event
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'form_submit', {
            form_name: 'contact_lesson_request',
            lang: formLang,
          });
        }
      } catch (err) {
        formError.classList.remove('hidden');
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-60', 'cursor-not-allowed');

        // Reset Turnstile
        if (window.turnstile) {
          window.turnstile.reset();
        }
      }
    });
  }
</script>
