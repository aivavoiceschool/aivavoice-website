---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromUrl, localizedPath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const ap = i.aboutPage;
---

<BaseLayout title={i.meta.about.title} description={i.meta.about.description}>

  <!-- PAGE HERO -->
  <section class="pt-36 pb-16 bg-white text-center">
    <div class="max-w-3xl mx-auto px-5">
      <span class="section-label justify-center">{ap.hero.label}</span>
      <h1 class="section-title text-forest-dark">{ap.hero.title}</h1>
      <p class="section-subtitle mx-auto">
        {ap.hero.subtitle}
      </p>
    </div>
  </section>

  <!-- FOUNDER -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Photo -->
        <div class="reveal">
          <div class="relative group">
            <div class="absolute -inset-3 bg-gradient-to-br from-gold/20 via-gold/5 to-transparent rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-sm" />
            <div class="relative aspect-[3/4] max-w-[420px] mx-auto rounded-3xl overflow-hidden border border-gray-200 shadow-[0_20px_60px_rgba(0,0,0,0.06)] group-hover:border-gold/30 group-hover:shadow-[0_24px_72px_rgba(212,160,23,0.12)] transition-all duration-500">
              <img
                src="/images/founder.jpg"
                alt={ap.founder.title}
                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105 group-hover:brightness-105"
                loading="lazy"
              />
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="reveal">
          <span class="section-label">{ap.founder.label}</span>
          <h2 class="section-title text-forest-dark">{ap.founder.title}</h2>

          <div class="space-y-4 mb-8">
            <p class="text-gray-600 leading-relaxed">
              {ap.founder.bio1}
            </p>
            <p class="text-gray-600 leading-relaxed" set:html={ap.founder.bio2} />
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
            {ap.founder.stats.map((s) => (
              <div class="bg-white border border-gray-200 rounded-xl p-4 text-center">
                <div class="text-gold text-2xl font-extrabold leading-none mb-1">{s.num}</div>
                <div class="text-gray-400 text-xs">{s.label}</div>
              </div>
            ))}
          </div>

          <!-- Experience -->
          <div class="bg-white border border-gray-200 rounded-2xl p-6 mb-6">
            <h4 class="text-forest-dark font-semibold text-sm mb-2 flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/>
              </svg>
              {ap.founder.experience.title}
            </h4>
            <p class="text-gray-500 text-sm leading-relaxed">
              {ap.founder.experience.text}
            </p>
          </div>

          <!-- Approach -->
          <div class="bg-white border border-gold/30 rounded-2xl p-6">
            <h4 class="text-forest-dark font-semibold text-sm mb-2 flex items-center gap-2">
              <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>
              </svg>
              {ap.founder.approach.title}
            </h4>
            <p class="text-gray-500 text-sm leading-relaxed" set:html={ap.founder.approach.text} />
          </div>

          <!-- Genre tags -->
          <div class="flex flex-wrap gap-2 mt-6">
            {ap.founder.genres.map((tag) => (
              <span class="px-4 py-1.5 rounded-full text-xs font-medium bg-gold/10 text-gold border border-gold/30">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TEACHING -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{ap.teaching.label}</span>
        <h2 class="section-title text-forest-dark">{ap.teaching.title}</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {ap.teaching.skills.map((item, idx) => (
          <div class="reveal group bg-white border border-gray-200 rounded-2xl p-7 hover:border-gold/40 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.08)] transition-all duration-500 relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-gold to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            <div class="absolute top-5 right-6 text-gray-100 text-5xl font-extrabold font-heading leading-none select-none">
              {String(idx + 1).padStart(2, '0')}
            </div>
            <div class="w-12 h-12 rounded-xl bg-forest/5 flex items-center justify-center mb-5 group-hover:bg-gold/15 transition-colors duration-300">
              {item.icon === 'mic' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/>
                </svg>
              )}
              {item.icon === 'music' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
                </svg>
              )}
              {item.icon === 'tune' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/>
                </svg>
              )}
              {item.icon === 'rhythm' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/>
                </svg>
              )}
              {item.icon === 'speak' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>
                </svg>
              )}
              {item.icon === 'stage' && (
                <svg class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                </svg>
              )}
            </div>
            <h3 class="text-forest-dark font-semibold text-base mb-2 relative">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed relative">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AGE GROUPS -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{ap.ageGroups.label}</span>
        <h2 class="section-title text-forest-dark">{ap.ageGroups.title}</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {ap.ageGroups.groups.map((group) => (
          <div class="reveal bg-white border border-gray-200 rounded-2xl overflow-hidden hover:-translate-y-1.5 hover:border-gold/30 hover:shadow-xl transition-all duration-300 group flex flex-col">
            <div class="h-44 flex items-center justify-center bg-gradient-to-br from-gray-50 to-gray-100 relative">
              <span class="text-6xl group-hover:scale-110 transition-transform duration-300">{group.emoji}</span>
              <span class="absolute top-4 right-4 px-3 py-1 bg-white backdrop-blur-sm rounded-full text-gold text-xs font-semibold border border-gray-200">
                {group.age}
              </span>
            </div>

            <div class="p-7 flex flex-col flex-1">
              <h3 class="font-heading text-xl font-bold text-forest-dark mb-4">{group.title}</h3>

              <ul class="space-y-2.5 mb-6 flex-1">
                {group.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-gray-600 text-sm">
                    <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                    </svg>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              <div class="pt-5 border-t border-gray-200">
                <div class="flex items-center gap-2 mb-1.5">
                  <svg class="w-4 h-4 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"/>
                  </svg>
                  <span class="text-gold text-xs font-bold uppercase tracking-wider">{ap.ageGroups.resultLabel}</span>
                </div>
                <p class="text-gray-500 text-sm leading-relaxed">{group.result}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative bg-gradient-to-b from-forest-dark via-forest to-forest-dark py-20 overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold/5 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-gold/3 rounded-full blur-3xl pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-5 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-cream mb-4">
        {ap.cta.title}
      </h2>
      <p class="text-cream/50 text-base md:text-lg mb-8 max-w-lg mx-auto">
        {ap.cta.subtitle}
      </p>
      <a href={localizedPath('/contact/', lang)} class="btn-gold !px-10 !py-4 !text-base group">
        {ap.cta.button}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>
