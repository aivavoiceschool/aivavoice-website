---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromUrl, localizedPath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
const tp = i.teachersPage;

const teacherPhotos: Record<string, { src: string; pos: string; scale?: boolean }> = {
  'Богдан Айвазян': { src: '/images/founder.jpg', pos: 'center 50%' },
  'Bohdan Aivazian': { src: '/images/founder.jpg', pos: 'center 50%' },
  'Софія Айвазян': { src: '/images/photo_aiva2.jpg', pos: 'center top' },
  'Sofia Aivazian': { src: '/images/photo_aiva2.jpg', pos: 'center top' },
  'Дар\'я Колобова': { src: '/images/teacher-daria.jpg', pos: 'center 45%' },
  'Daria Kolobova': { src: '/images/teacher-daria.jpg', pos: 'center 45%' },
  'Анна Скоростенська': { src: '/images/teacher-anna.jpg', pos: 'center 20%' },
  'Anna Skorostenska': { src: '/images/teacher-anna.jpg', pos: 'center 20%' },
  'Юлія Кішінська': { src: '/images/teacher-yuliia.jpg', pos: 'center 20%' },
  'Yuliia Kishinska': { src: '/images/teacher-yuliia.jpg', pos: 'center 20%' },
};
---

<BaseLayout title={i.meta.teachers.title} description={i.meta.teachers.description}>

  <!-- ====== HERO ====== -->
  <section class="relative pt-36 pb-20 bg-gradient-to-b from-forest-dark via-forest to-forest-light text-center overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-gold/5 rounded-full blur-[120px]" />
      <div class="absolute -bottom-24 -left-24 w-[350px] h-[350px] bg-gold/3 rounded-full blur-[100px]" />
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-5">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full text-xs font-semibold uppercase tracking-widest text-gold/80 mb-6 backdrop-blur-sm">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
        </svg>
        {tp.hero.label}
      </span>
      <h1 class="font-heading text-2xl sm:text-3xl md:text-4xl font-bold text-white leading-[1.2] mb-6 max-w-2xl mx-auto">
        {tp.hero.title}
      </h1>
      <p class="text-white/50 text-base md:text-lg max-w-2xl mx-auto leading-relaxed">
        {tp.hero.subtitle}
      </p>
    </div>

    <!-- Decorative bottom wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none" class="w-full h-12 md:h-16">
        <path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 V80 H0 Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- ====== INTRO ====== -->
  <section class="pt-8 pb-4 bg-white">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <p class="text-gray-500 text-lg leading-relaxed">{tp.intro.text}</p>
    </div>
  </section>

  <!-- ====== TEACHERS ====== -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-5 space-y-24">
      {tp.teachers.map((teacher, idx) => (
        <div class="reveal">
          <div class:list={[
            'grid lg:grid-cols-[420px_1fr] gap-10 lg:gap-16 items-start max-w-6xl mx-auto',
            idx % 2 === 1 && 'lg:grid-cols-[1fr_420px] [&>*:first-child]:lg:order-2',
          ]}>

            {/* ── Photo Card ── */}
            <div class="relative group">
              {/* Gold accent line */}
              <div class="absolute -inset-3 bg-gradient-to-br from-gold/20 via-gold/5 to-transparent rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-sm" />

              {teacherPhotos[teacher.name] ? (
                <div class="relative aspect-[3/4] max-w-[420px] mx-auto rounded-3xl overflow-hidden border border-gray-200 shadow-[0_20px_60px_rgba(0,0,0,0.06)] group-hover:border-gold/30 group-hover:shadow-[0_24px_72px_rgba(212,160,23,0.12)] transition-all duration-500">
                  <img
                    src={teacherPhotos[teacher.name].src}
                    alt={teacher.name}
                    class="w-full h-full object-cover teacher-photo-hover transition-all duration-700"
                    style={`object-position: ${teacherPhotos[teacher.name].pos}; ${teacherPhotos[teacher.name].scale ? 'transform: scale(1.5);' : ''}`}
                    loading="lazy"
                  />
                  {/* Vignette overlay */}
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 via-transparent to-transparent pointer-events-none" />
                  {/* Number badge */}
                  <div class="absolute top-5 left-5 w-10 h-10 rounded-full bg-white/90 backdrop-blur-sm border border-white/50 shadow-sm flex items-center justify-center">
                    <span class="text-gold font-bold text-sm">{String(idx + 1).padStart(2, '0')}</span>
                  </div>
                </div>
              ) : (
                <div class="relative aspect-[3/4] max-w-[420px] mx-auto rounded-3xl bg-gradient-to-br from-gray-50 via-white to-gray-100 border border-gray-200 shadow-[0_20px_60px_rgba(0,0,0,0.06)] flex flex-col items-center justify-center gap-5 overflow-hidden group-hover:border-gold/30 group-hover:shadow-[0_24px_72px_rgba(212,160,23,0.12)] transition-all duration-500">
                  <div class="absolute top-8 right-8 w-20 h-20 bg-gold/5 rounded-full" />
                  <div class="absolute bottom-12 left-8 w-14 h-14 bg-forest/5 rounded-full" />

                  <div class="w-28 h-28 rounded-full bg-gradient-to-br from-forest/10 to-gold/10 border-2 border-gray-200 flex items-center justify-center group-hover:border-gold/40 transition-colors duration-500">
                    <svg class="w-14 h-14 text-gray-300 group-hover:text-gray-400 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                    </svg>
                  </div>

                  <div class="text-center px-6">
                    <p class="text-gray-400 text-sm font-medium">{teacher.name}</p>
                    <p class="text-gray-300 text-xs mt-1">{teacher.role}</p>
                  </div>

                  <div class="absolute top-5 left-5 w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center">
                    <span class="text-gold font-bold text-sm">{String(idx + 1).padStart(2, '0')}</span>
                  </div>
                </div>
              )}
            </div>

            {/* ── Info ── */}
            <div class="flex flex-col justify-center">
              {/* Name & role */}
              <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-10 h-10 rounded-full bg-gold/10 flex items-center justify-center shrink-0">
                    <span class="text-gold font-bold text-xs">{teacher.initials}</span>
                  </div>
                  <div>
                    <h2 class="font-heading text-2xl md:text-3xl font-bold text-forest-dark leading-tight">{teacher.name}</h2>
                    <p class="text-gold text-sm font-semibold uppercase tracking-wider">{teacher.role}</p>
                  </div>
                </div>
              </div>

              {/* Divider */}
              <div class="w-16 h-[2px] bg-gradient-to-r from-gold to-gold/20 mb-6" />

              {/* Bio */}
              {teacher.bio ? (
                <div class="text-gray-600 leading-relaxed mb-8 text-[15px] space-y-4" set:html={teacher.bio} />
              ) : (
                <div class="bg-gray-50 border border-dashed border-gray-200 rounded-2xl p-6 mb-8">
                  <p class="text-gray-300 text-sm italic text-center">
                    {lang === 'uk' ? 'Біографія буде додана незабаром' : 'Biography coming soon'}
                  </p>
                </div>
              )}

              {/* Stats row */}
              {teacher.experience && (
                <div class="grid grid-cols-2 gap-3 mb-8">
                  <div class="bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl p-5 text-center hover:border-gold/30 hover:shadow-md transition-all duration-300">
                    <div class="text-gold text-2xl md:text-3xl font-extrabold leading-none mb-1.5">{teacher.experience}</div>
                    <div class="text-gray-400 text-[11px] uppercase tracking-wider font-medium">{teacher.experienceLabel}</div>
                  </div>
                  <div class="bg-gradient-to-br from-white to-gray-50 border border-gray-200 rounded-2xl p-5 text-center hover:border-gold/30 hover:shadow-md transition-all duration-300">
                    <div class="text-gold text-2xl md:text-3xl font-extrabold leading-none mb-1.5">{teacher.ages}</div>
                    <div class="text-gray-400 text-[11px] uppercase tracking-wider font-medium">{teacher.agesLabel}</div>
                  </div>
                </div>
              )}

              {/* Tags */}
              {teacher.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-8">
                  {teacher.tags.map((tag) => (
                    <span class="px-4 py-2 rounded-full text-xs font-semibold bg-gold/8 text-gold border border-gold/20 hover:bg-gold/15 transition-colors duration-200">{tag}</span>
                  ))}
                </div>
              )}

              {/* Quote */}
              {teacher.quote && (
                <div class="relative bg-gradient-to-br from-forest-dark to-forest rounded-2xl p-7 text-white overflow-hidden">
                  <div class="absolute top-3 left-5 text-gold/20 text-6xl font-heading leading-none select-none">&ldquo;</div>
                  <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-gold/5 rounded-full blur-xl" />
                  <blockquote class="relative text-cream/80 text-sm md:text-[15px] leading-relaxed italic pl-6 border-l-2 border-gold/40">
                    {teacher.quote}
                  </blockquote>
                </div>
              )}
            </div>
          </div>

          {/* Separator between teachers */}
          {idx < tp.teachers.length - 1 && (
            <div class="flex items-center justify-center gap-3 mt-24">
              <div class="w-24 h-px bg-gradient-to-r from-transparent to-gray-200" />
              <svg class="w-5 h-5 text-gold/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
              </svg>
              <div class="w-24 h-px bg-gradient-to-l from-transparent to-gray-200" />
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ====== WHY US ====== -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{tp.why.label}</span>
        <h2 class="section-title text-forest-dark">{tp.why.title}</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {tp.why.items.map((item, idx) => (
          <div class="reveal stagger group bg-white border border-gray-200 rounded-2xl p-7 hover:border-gold/40 hover:-translate-y-1.5 hover:shadow-[0_16px_40px_rgba(26,74,46,0.08)] transition-all duration-500 relative overflow-hidden" style={`--stagger: ${idx}`}>
            <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-gold to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

            <div class="w-14 h-14 rounded-2xl bg-forest/5 flex items-center justify-center mb-5 group-hover:bg-gold/15 transition-colors duration-300">
              {item.icon === 'person' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                </svg>
              )}
              {item.icon === 'star' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
              )}
              {item.icon === 'heart' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
              )}
              {item.icon === 'music' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 11-.99-3.467l2.31-.66a2.25 2.25 0 001.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 01-1.632 2.163l-1.32.377a1.803 1.803 0 01-.99-3.467l2.31-.66A2.25 2.25 0 009 15.553z"/>
                </svg>
              )}
            </div>

            <h3 class="text-forest font-semibold text-base mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <section class="relative bg-gradient-to-b from-forest-dark via-forest to-forest-dark py-20 overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold/5 rounded-full blur-3xl pointer-events-none" />
    <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-gold/3 rounded-full blur-3xl pointer-events-none" />

    <div class="relative max-w-7xl mx-auto px-5 text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-cream mb-4">
        {tp.cta.title}
      </h2>
      <p class="text-cream/50 text-base md:text-lg mb-8 max-w-lg mx-auto">
        {tp.cta.subtitle}
      </p>
      <a href={localizedPath('/contact/', lang)} class="btn-gold !px-10 !py-4 !text-base group">
        {tp.cta.button}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>

<style is:global>
  .teacher-photo-hover {
    transform: scale(1);
    filter: brightness(1);
  }
  .group:hover .teacher-photo-hover {
    transform: scale(1.05);
    filter: brightness(1.05);
  }
</style>
