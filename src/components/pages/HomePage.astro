---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../CtaBanner.astro';
import { t, getLangFromUrl, localizedPath } from '../../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<BaseLayout title={i.meta.home.title} description={i.meta.home.description}>

  <!-- ====== HERO ====== -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden bg-gradient-to-b from-forest-dark via-forest to-forest-light">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-32 -right-32 w-[500px] h-[500px] bg-gold/5 rounded-full blur-[120px]" />
      <div class="absolute -bottom-24 -left-24 w-[350px] h-[350px] bg-gold/3 rounded-full blur-[100px]" />

      <span class="hero-float absolute text-[2.5rem] left-[5%] top-[12%] text-white/[0.12]" style="--dur:21s;--delay:0s;--dx:18px;--dy:-22px">&#9835;</span>
      <span class="hero-float absolute text-[1.8rem] left-[18%] top-[55%] text-white/[0.10]" style="--dur:26s;--delay:-4s;--dx:-14px;--dy:20px">&#9834;</span>
      <span class="hero-float absolute text-[3.2rem] left-[12%] top-[35%] text-gold/[0.14]" style="--dur:19s;--delay:-9s;--dx:22px;--dy:15px">&#9833;</span>
      <span class="hero-float absolute text-[2rem] right-[8%] top-[18%] text-white/[0.12]" style="--dur:24s;--delay:-2s;--dx:-20px;--dy:-18px">&#9835;</span>
      <span class="hero-float absolute text-[2.8rem] right-[22%] top-[62%] text-white/[0.10]" style="--dur:20s;--delay:-11s;--dx:16px;--dy:25px">&#9834;</span>
      <span class="hero-float absolute text-[1.5rem] left-[40%] top-[8%] text-gold/[0.12]" style="--dur:28s;--delay:-6s;--dx:-10px;--dy:-15px">&#9835;</span>
      <span class="hero-float absolute text-[2.2rem] right-[38%] top-[72%] text-white/[0.08]" style="--dur:22s;--delay:-14s;--dx:12px;--dy:-20px">&#9833;</span>
      <span class="hero-float absolute text-[3rem] left-[65%] top-[25%] text-white/[0.10]" style="--dur:25s;--delay:-8s;--dx:-18px;--dy:12px">&#9834;</span>
      <span class="hero-float absolute text-[1.6rem] left-[82%] top-[45%] text-gold/[0.12]" style="--dur:18s;--delay:-3s;--dx:14px;--dy:-22px">&#9835;</span>
      <span class="hero-float absolute text-[2.4rem] left-[50%] top-[68%] text-white/[0.08]" style="--dur:23s;--delay:-16s;--dx:-16px;--dy:18px">&#9834;</span>
      <span class="hero-float absolute text-[1.4rem] left-[30%] top-[78%] text-gold/[0.10]" style="--dur:27s;--delay:-7s;--dx:20px;--dy:-12px">&#9833;</span>
      <span class="hero-float absolute text-[2rem] right-[12%] top-[50%] text-white/[0.12]" style="--dur:21s;--delay:-13s;--dx:-12px;--dy:16px">&#9835;</span>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-5 py-32">
      <div class="hero-fade inline-flex items-center gap-2.5 px-5 py-2.5 bg-white/5 border border-white/10 rounded-full text-sm font-medium text-white/80 mb-10 backdrop-blur-sm" style="--fade-order: 0">
        <span class="w-2 h-2 bg-gold rounded-full animate-pulse" />
        {i.hero.badge}
      </div>

      <h1 class="font-heading text-[2.2rem] sm:text-5xl md:text-6xl lg:text-[4.5rem] font-bold leading-[1.08] mb-8" style="--fade-order: 1">
        <span class="hero-title-line block text-white">
          {i.hero.title}
        </span>
        <span class="hero-fade block mt-2 text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem]" style="--fade-order: 1.5">
          <span class="hero-accent-text relative inline-block">
            {i.hero.titleAccent}
            <svg class="absolute -bottom-2 left-0 w-full h-3 hero-underline" viewBox="0 0 200 12" fill="none" preserveAspectRatio="none">
              <path d="M2 8c40-6 80-6 98-2s60 4 98-2" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
        </span>
      </h1>

      <!-- Stats cards -->
      <div class="hero-fade grid grid-cols-3 gap-2 max-w-sm mx-auto mb-5" style="--fade-order: 2.2">
        {i.hero.stats.map((stat) => (
          <div class="bg-white/[0.06] border border-white/10 rounded-xl py-2.5 px-2 text-center backdrop-blur-sm hover:border-gold/30 hover:bg-white/[0.1] transition-all duration-300">
            <div class="text-gold text-base md:text-xl font-extrabold leading-none mb-1">
              {stat.num}
            </div>
            <div class="text-white/40 text-[9px] md:text-[11px] uppercase tracking-wider font-medium leading-tight">
              {stat.label}
            </div>
          </div>
        ))}
      </div>

      <p class="hero-fade text-white/40 text-xs md:text-sm tracking-wide mb-2" style="--fade-order: 2.7">
        {lang === 'uk' ? 'Рейтинг наших учнів' : 'Our students\' rating'}
      </p>
      <!-- Stars -->
      <div class="hero-fade flex items-center justify-center gap-1 mb-5" style="--fade-order: 2.8">
        {[1,2,3,4,5].map(() => (
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>

      <a href={localizedPath('/contact/', lang)} class="hero-cta-btn btn-gold !px-8 !py-4 !text-sm md:!px-10 md:!py-5 md:!text-base group relative overflow-hidden" style="--fade-order: 3">
        <span class="hero-cta-shimmer absolute inset-0 pointer-events-none" />
        <span class="relative flex items-center gap-2">
          {i.hero.cta}
          <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </span>
      </a>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 text-xs animate-bounce">
      <span>{i.hero.scroll}</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M10 4v12M5 11l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- ====== ADVANTAGES ====== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{i.advantages.label}</span>
        <h2 class="section-title">{i.advantages.title}</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {i.advantages.items.map((item, idx) => (
          <div class="reveal stagger group bg-white border border-gray-200 rounded-2xl p-7 hover:border-gold/40 hover:-translate-y-1.5 hover:shadow-[0_16px_40px_rgba(26,74,46,0.08)] transition-all duration-500 relative overflow-hidden" style={`--stagger: ${idx}`}>
            <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-transparent via-gold to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

            <div class="w-14 h-14 rounded-2xl bg-forest/5 flex items-center justify-center mb-5 group-hover:bg-forest/10 transition-colors duration-300">
              {item.icon === 'person' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
                </svg>
              )}
              {item.icon === 'globe' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>
                </svg>
              )}
              {item.icon === 'star' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
              )}
              {item.icon === 'clock' && (
                <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              )}
            </div>

            <h3 class="text-forest font-semibold text-base mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FORMATS ====== -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{i.formats.label}</span>
        <h2 class="section-title">{i.formats.title}</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {[i.formats.online, i.formats.offline].map((format, idx) => (
          <div class="reveal bg-white border border-gray-200 rounded-2xl overflow-hidden hover:border-gold/40 hover:shadow-lg transition-all duration-300">
            <div class:list={[
              'px-7 py-5 flex items-center gap-3 border-b border-gray-100',
              idx === 0 ? 'bg-forest/[0.03]' : 'bg-gold/[0.04]',
            ]}>
              <div class="w-10 h-10 rounded-xl bg-forest/8 flex items-center justify-center">
                {idx === 0 ? (
                  <svg class="w-5 h-5 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a9 9 0 11-18 0V5.25"/>
                  </svg>
                ) : (
                  <svg class="w-5 h-5 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                  </svg>
                )}
              </div>
              <div>
                <span class="text-gold text-xs font-bold uppercase tracking-wider">{format.badge}</span>
                <h3 class="text-forest font-semibold text-lg font-heading">{format.title}</h3>
              </div>
            </div>

            <div class="px-7 py-6 space-y-4">
              {format.features.map((f) => (
                <div class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                  <div>
                    <span class="text-gray-400 text-xs font-semibold uppercase tracking-wider">{f.label}</span>
                    <p class="text-forest-dark text-sm font-medium">{f.value}</p>
                  </div>
                </div>
              ))}

              <div class="pt-4 mt-4 border-t border-gray-100">
                <span class="text-gold text-xs font-bold uppercase tracking-wider">{i.formats.suitedLabel}</span>
                <p class="text-gray-500 text-sm leading-relaxed mt-1">{format.suited}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== TESTIMONIALS ====== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{i.testimonials.label}</span>
        <h2 class="section-title">{i.testimonials.title}</h2>
        <p class="section-subtitle mx-auto">{i.testimonials.subtitle}</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {i.testimonials.items.map((item, idx) => (
          <div class="reveal stagger bg-gray-50 border border-gray-200 rounded-2xl p-7 hover:border-gold/30 hover:-translate-y-1 hover:shadow-md transition-all duration-300 flex flex-col" style={`--stagger: ${idx}`}>
            <div class="text-gold/30 text-5xl font-heading leading-none mb-3">&ldquo;</div>
            <blockquote class="text-gray-600 text-sm leading-relaxed mb-6 flex-1 italic">
              {item.text}
            </blockquote>
            <div class="flex items-center gap-3 pt-5 border-t border-gray-100">
              <div class="w-10 h-10 rounded-full bg-forest/8 flex items-center justify-center text-sm font-bold text-forest shrink-0">
                {item.name.charAt(0)}
              </div>
              <div>
                <div class="text-forest-dark text-sm font-semibold">{item.name}</div>
                <div class="text-gray-400 text-xs">{item.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FAQ ====== -->
  <section class="py-20 md:py-28 bg-gray-50">
    <div class="max-w-3xl mx-auto px-5">
      <div class="text-center mb-14 reveal">
        <span class="section-label justify-center">{i.homeFaq.label}</span>
        <h2 class="section-title">{i.homeFaq.title}</h2>
      </div>

      <div class="space-y-3">
        {i.homeFaq.items.map((item, idx) => (
          <div class="reveal stagger" data-faq style={`--stagger: ${idx}`}>
            <button
              data-faq-btn
              class="w-full flex items-center justify-between gap-4 px-6 py-5 bg-white border border-gray-200 rounded-2xl text-left hover:border-gold/30 transition-all duration-300 cursor-pointer group"
            >
              <span class="text-forest-dark font-semibold text-[15px] leading-snug">{item.q}</span>
              <span class="faq-icon w-7 h-7 rounded-full bg-forest/5 flex items-center justify-center shrink-0 group-hover:bg-gold/10 transition-all duration-300">
                <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                </svg>
              </span>
            </button>
            <div class="faq-answer overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]" style="max-height: 0px;">
              <div class="px-6 pt-3 pb-5 text-gray-500 text-sm leading-relaxed">
                {item.a}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== CTA ====== -->
  <CtaBanner />

</BaseLayout>

<style is:global>
  /* ===== Hero floating notes ===== */
  .hero-float {
    animation: heroFloat var(--dur, 20s) ease-in-out var(--delay, 0s) infinite;
    will-change: transform;
  }

  @keyframes heroFloat {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
    25% {
      transform: translate(var(--dx, 15px), var(--dy, -20px)) rotate(4deg) scale(1.05);
    }
    50% {
      transform: translate(calc(var(--dx, 15px) * -0.7), calc(var(--dy, -20px) * -0.6)) rotate(-3deg) scale(0.95);
    }
    75% {
      transform: translate(calc(var(--dx, 15px) * 0.5), calc(var(--dy, -20px) * 0.8)) rotate(2deg) scale(1.02);
    }
  }

  /* ===== Hero fade-in on load ===== */
  .hero-fade {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFadeIn 0.8s ease-out forwards;
    animation-delay: calc(var(--fade-order, 0) * 0.18s + 0.2s);
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== Hero title letter-spacing animation ===== */
  .hero-title-line {
    opacity: 0;
    letter-spacing: 0.04em;
    animation: heroTitleReveal 1.2s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }
  @keyframes heroTitleReveal {
    0% {
      opacity: 0;
      letter-spacing: 0.25em;
      filter: blur(8px);
      transform: translateY(24px);
    }
    100% {
      opacity: 1;
      letter-spacing: 0.04em;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  /* ===== Gold accent shimmer text ===== */
  .hero-accent-text {
    background: linear-gradient(
      110deg,
      var(--color-gold) 0%,
      #f5e6a3 20%,
      var(--color-gold) 40%,
      #ffe4a0 60%,
      var(--color-gold) 80%,
      #f5e6a3 100%
    );
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation:
      heroAccentReveal 1s cubic-bezier(0.22, 1, 0.36, 1) 0.7s both,
      heroAccentShimmer 6s ease-in-out 2s infinite;
  }
  @keyframes heroAccentReveal {
    0% {
      opacity: 0;
      filter: blur(6px);
      transform: translateY(16px) scale(0.95);
    }
    100% {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0) scale(1);
    }
  }
  @keyframes heroAccentShimmer {
    0% { background-position: 100% 50%; }
    50% { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  /* ===== Underline draw animation ===== */
  .hero-underline {
    color: rgba(212, 160, 23, 0.2);
    stroke-dasharray: 300;
    stroke-dashoffset: 300;
    animation: heroUnderlineDraw 1.2s ease-out 1.2s forwards;
  }
  @keyframes heroUnderlineDraw {
    to { stroke-dashoffset: 0; }
  }

  /* ===== Hero CTA button ===== */
  .hero-cta-btn {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    animation: heroCTAReveal 0.8s cubic-bezier(0.22, 1, 0.36, 1) 1.4s both;
    box-shadow: 0 8px 32px rgba(212, 160, 23, 0.35);
  }
  .hero-cta-btn:hover {
    box-shadow: 0 12px 48px rgba(212, 160, 23, 0.5);
    transform: translateY(-2px) scale(1.03);
  }
  .hero-cta-btn {
    transition: box-shadow 0.4s, transform 0.4s;
  }
  @keyframes heroCTAReveal {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
      filter: blur(4px);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  /* CTA shimmer sweep */
  .hero-cta-shimmer {
    background: linear-gradient(
      105deg,
      transparent 35%,
      rgba(255, 255, 255, 0.15) 45%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0.15) 55%,
      transparent 65%
    );
    background-size: 300% 100%;
    animation: heroCTAShimmer 4s ease-in-out 2.5s infinite;
    border-radius: inherit;
  }
  @keyframes heroCTAShimmer {
    0% { background-position: 150% 0; }
    100% { background-position: -150% 0; }
  }

  /* Pulse glow ring */
  .hero-cta-btn::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(212, 160, 23, 0.4), transparent, rgba(212, 160, 23, 0.4));
    opacity: 0;
    animation: heroCTAPulse 3s ease-in-out 3s infinite;
    z-index: -1;
  }
  @keyframes heroCTAPulse {
    0%, 100% { opacity: 0; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.04); }
  }

  /* ===== Stagger delay for scroll-reveal cards ===== */
  .reveal.stagger {
    transition-delay: calc(var(--stagger, 0) * 0.12s);
  }
</style>

<script>
  document.querySelectorAll('[data-faq-btn]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('[data-faq]');
      const answer = item?.querySelector('.faq-answer') as HTMLElement;
      const icon = item?.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer?.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all
      document.querySelectorAll('[data-faq]').forEach((el) => {
        const a = el.querySelector('.faq-answer') as HTMLElement;
        const ic = el.querySelector('.faq-icon') as HTMLElement;
        if (a) a.style.maxHeight = '0px';
        if (ic) ic.style.transform = 'rotate(0deg)';
      });

      // Open clicked if was closed
      if (!isOpen && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        if (icon) icon.style.transform = 'rotate(45deg)';
      }
    });
  });
</script>
