---
import { t, getLangFromUrl, localizedPath } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<section class="relative bg-gradient-to-b from-forest-dark via-forest to-forest-dark py-20 overflow-hidden">
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-gold/8 rounded-full blur-3xl pointer-events-none" />
  <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-gold/5 rounded-full blur-3xl pointer-events-none" />

  <div class="relative max-w-7xl mx-auto px-5 text-center">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
      {i.cta.title}
    </h2>
    <p class="text-white/50 text-base md:text-lg mb-8 max-w-lg mx-auto">
      {i.cta.subtitle}
    </p>
    <a href={localizedPath('/contact/', lang)} class="btn-gold !px-10 !py-4 !text-base">
      {i.cta.button}
    </a>
  </div>
</section>
