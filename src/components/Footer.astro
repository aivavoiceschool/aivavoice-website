---
import { t, getLangFromUrl, localizedPath } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const i = t(lang);
---

<footer class="bg-forest-dark border-t border-forest-dark">
  <div class="max-w-7xl mx-auto px-5 pt-16 pb-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div>
        <a href={localizedPath('/', lang)} class="font-heading text-2xl font-bold tracking-wide inline-block mb-4">
          <span class="text-white">Aiva</span><span class="text-gold">Voice</span>
        </a>
        <p class="text-white/40 text-sm leading-relaxed max-w-[280px]">{i.footer.description}</p>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-5 tracking-wide">{i.footer.navTitle}</h4>
        <ul class="space-y-3">
          <li><a href={localizedPath('/', lang)} class="text-white/40 text-sm hover:text-gold transition-colors">{i.nav.home}</a></li>
          <li><a href={localizedPath('/about/', lang)} class="text-white/40 text-sm hover:text-gold transition-colors">{i.nav.about}</a></li>
          <li><a href={localizedPath('/reviews/', lang)} class="text-white/40 text-sm hover:text-gold transition-colors">{i.nav.reviews}</a></li>
          <li><a href={localizedPath('/pricing/', lang)} class="text-white/40 text-sm hover:text-gold transition-colors">{i.nav.pricing}</a></li>
          <li><a href={localizedPath('/contact/', lang)} class="text-white/40 text-sm hover:text-gold transition-colors">{i.nav.contact}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-5 tracking-wide">{i.footer.contactsTitle}</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <a href="tel:+380685490047" class="text-white font-bold hover:text-gold transition-colors" style="font-size: 20px;">{i.footer.phone}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold/60 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
            <a href="https://t.me/aivavoiceschool" target="_blank" rel="noopener" class="text-white/40 text-sm hover:text-gold transition-colors">Telegram {i.footer.telegram}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold/60 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91-.01-2.65-1.04-5.13-2.9-6.99A9.816 9.816 0 0012.04 2zm5.63 13.59c-.23.65-1.36 1.22-1.89 1.3-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.65-.6-2.9-1.24-4.79-4.15-4.93-4.34-.15-.19-1.17-1.56-1.17-2.97 0-1.42.74-2.12 1-2.41.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.66.5.24.58.82 2 .89 2.15.07.14.12.31.02.5-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.78 1.28 1.67 2.07 1.14 1.02 2.11 1.33 2.41 1.48.29.15.46.13.64-.08.17-.21.75-.87.95-1.17.19-.29.39-.24.66-.15.27.1 1.71.81 2 .95.29.15.48.22.56.34.07.12.07.68-.16 1.33z"/></svg>
            <a href="viber://chat?number=%2B380685490047" class="text-white/40 text-sm hover:text-gold transition-colors">Viber {i.footer.viber}</a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="text-white text-sm font-semibold mb-5 tracking-wide">{i.footer.socialTitle}</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold/60 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            <a href="https://instagram.com/aivavoice" target="_blank" rel="noopener" class="text-white/40 text-sm hover:text-gold transition-colors">Instagram {i.footer.instagram}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold/60 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.75a8.16 8.16 0 004.77 1.52V6.84a4.84 4.84 0 01-1.01-.15z"/></svg>
            <a href="https://tiktok.com/@aivavoice5" target="_blank" rel="noopener" class="text-white/40 text-sm hover:text-gold transition-colors">TikTok {i.footer.tiktok}</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/30">
      <p>{i.footer.copyright}</p>
      <a href="#" class="text-gold/60 hover:text-gold transition-colors">{i.footer.privacy}</a>
    </div>
  </div>
</footer>
